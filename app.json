{
  "expo": {
    "name": "PlayThread",
    "slug": "PlayThread",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "playthread",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "app.playthread.mobile",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "PlayThread sends notifications for replies, followers, gifts, moderation warnings, and posts from games you follow.",
        "NSPhotoLibraryUsageDescription": "PlayThread uses your photo library so you can attach screenshots and clips to posts and update your profile media.",
        "NSPhotoLibraryAddUsageDescription": "PlayThread may save exported media or temporary assets needed to share screenshots and clips.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#0B1017",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PlayThread uses your photo library so you can attach screenshots and clips to posts and update your profile media."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "abdbb665-1d8f-4924-9174-863608ab17b5"
      }
    },
    "owner": "itsamirage",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/abdbb665-1d8f-4924-9174-863608ab17b5"
    }
  }
}
